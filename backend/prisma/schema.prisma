generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  role         UserRole @default(ORGANIZER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  competitions          Competition[]
  // Competitors registered by this user (organizer or coach acting on
  // behalf of an athlete). Public self-registrations leave this null.
  registeredCompetitors Competitor[]  @relation("RegisteredBy")
}

enum UserRole {
  ORGANIZER
  ADMIN
  // Coach acting on behalf of athletes from their club. Same auth
  // mechanism as ORGANIZER but scoped reads/writes (only sees their
  // registered athletes). Per-role permission gates land alongside the
  // coach-account UI; this enum value just reserves the slot.
  COACH
}

// ─── Competition ───

model Competition {
  id                     String            @id @default(cuid())
  name                   String
  date                   DateTime
  location               String            @default("")
  status                 CompetitionStatus @default(DRAFT)
  organizerId            String
  organizer              User              @relation(fields: [organizerId], references: [id])
  matchDuration          Int               @default(240)
  goldenScoreLimit       Int               @default(0)
  // Max competitors allowed per projected IJF category (gender + ageGroup +
  // weightLabel). Null disables the cap. Single shared value for now —
  // per-class differentiated caps are a follow-up. Mat-time math typically
  // breaks above 24-32 fighters per class.
  maxEntriesPerCategory  Int?

  categories  Category[]
  competitors Competitor[]
  mats        Mat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerId])
}

enum CompetitionStatus {
  DRAFT
  REGISTRATION
  WEIGH_IN
  ACTIVE
  COMPLETED
}

// ─── Category ───

model Category {
  id            String      @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  name          String
  gender        Gender
  ageGroup      AgeGroup
  minWeight     Decimal
  maxWeight     Decimal
  bracketType   BracketType @default(ROUND_ROBIN)
  matId         String?
  mat           Mat?        @relation(fields: [matId], references: [id], onDelete: SetNull)

  competitors Competitor[]
  matches     Match[]

  @@index([competitionId])
  @@index([matId])
}

enum Gender {
  MALE
  FEMALE
}

enum AgeGroup {
  U13
  U15
  CADET
  JUNIOR
  SENIOR
  VETERAN
}

enum BracketType {
  ROUND_ROBIN
  POOLS
  SINGLE_REPECHAGE
  DOUBLE_REPECHAGE
  // IJF Grand Slam format: 4 pools, single-elim internal, pool winners
  // feed a 4-team knockout, pool finalist-losers fight cross-half
  // repechage for two distinct bronze medals.
  GRAND_SLAM
}

enum MatchPhase {
  POOL
  KNOCKOUT_SF
  KNOCKOUT_FINAL
  KNOCKOUT_BRONZE
  REPECHAGE
}

// ─── Athlete (persistent identity across tournaments) ───
//
// One row per real-world person. Foundation for cross-tournament history,
// coach accounts ("show me all my athletes"), late-add by lookup, and
// federation rankings.
//
// A Competitor is a per-competition registration; an Athlete is the person
// that registration represents. New registrations auto-link to an existing
// Athlete by email (when present) or create a fresh one. athleteId on
// Competitor stays nullable during the transition so existing rows keep
// working until backfilled.

model Athlete {
  id            String     @id @default(cuid())
  firstName     String
  lastName      String
  dateOfBirth   DateTime
  gender        Gender
  // Email is one natural dedup key across tournaments. Nullable so
  // walk-up registrants without email don't all collide on empty string.
  email         String?    @unique
  // Federation license number — more stable than email (an athlete keeps
  // it when they switch clubs or email providers). Used as a secondary
  // auto-match key when present. Same nullable+unique pattern.
  licenseNumber String?    @unique

  competitors Competitor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName, firstName])
}

// ─── Competitor ───

model Competitor {
  id                 String             @id @default(cuid())
  competitionId      String
  competition        Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  categoryId         String?
  category           Category?          @relation(fields: [categoryId], references: [id])
  athleteId          String?
  athlete            Athlete?           @relation(fields: [athleteId], references: [id])
  // Who registered this competitor. Public self-registrations leave this
  // null. Coach- and organizer-driven registrations populate it for audit
  // and "my athletes" filters.
  registeredById     String?
  registeredBy       User?              @relation("RegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)
  firstName          String
  lastName           String
  email              String             @default("")
  dateOfBirth        DateTime
  gender             Gender
  weight             Decimal?
  belt               Belt               @default(WHITE)
  club               String             @default("")
  registrationStatus RegistrationStatus @default(REGISTERED)

  // Payment tracking (forward-looking). All nullable for backward compat
  // with existing rows and free events. paymentIntentId is unique so
  // Stripe webhook handlers can dedupe by it (idempotency requirement
  // flagged in the Smoothcomp eng review). Decimal column for amount;
  // refundedAt non-null means a refund was processed (use refund amount
  // == paidAmount for full refunds; partial refunds need a separate table
  // when we get there).
  paymentIntentId    String?            @unique
  paidAt             DateTime?
  paidAmount         Decimal?           @db.Decimal(10, 2)
  refundedAt         DateTime?

  matchesAsCompetitor1 Match[] @relation("Competitor1")
  matchesAsCompetitor2 Match[] @relation("Competitor2")
  matchesWon           Match[] @relation("Winner")

  createdAt DateTime @default(now())

  @@index([competitionId])
  @@index([categoryId])
  @@index([athleteId])
  @@index([registeredById])
}

enum Belt {
  WHITE
  YELLOW
  ORANGE
  GREEN
  BLUE
  BROWN
  BLACK_1DAN
  BLACK_2DAN
  BLACK_3DAN
  BLACK_4DAN
  BLACK_5DAN
}

enum RegistrationStatus {
  REGISTERED
  WEIGHED_IN
  WITHDRAWN
}

// ─── Mat ───

model Mat {
  id             String      @id @default(cuid())
  competitionId  String
  competition    Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  number         Int
  pin            String      @default("")
  currentMatchId String?

  matches    Match[]
  categories Category[]

  @@unique([competitionId, number])
  @@index([competitionId])
}

// ─── Match ───

model Match {
  id            String      @id @default(cuid())
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  matId         String?
  mat           Mat?        @relation(fields: [matId], references: [id])
  round         Int         @default(0)
  poolPosition  Int         @default(0)
  competitor1Id String?
  competitor1   Competitor? @relation("Competitor1", fields: [competitor1Id], references: [id])
  competitor2Id String?
  competitor2   Competitor? @relation("Competitor2", fields: [competitor2Id], references: [id])
  winnerId      String?
  winner        Competitor? @relation("Winner", fields: [winnerId], references: [id])
  winMethod     WinMethod?
  scores        Json?
  status        MatchStatus @default(SCHEDULED)
  duration      Int         @default(240)
  goldenScore   Boolean     @default(false)
  sequenceNum   Int         @default(0)
  phase         MatchPhase?
  poolGroup     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([matId])
}

enum WinMethod {
  IPPON
  WAZA_ARI
  DECISION
  HANSOKU_MAKE
  FUSEN_GACHI
  KIKEN_GACHI
}

enum MatchStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
}
